---
/*
 * Oriz Echo — audio tools home.
 * 8 Web Audio API tools, all client-side, no ffmpeg.
 */
import BaseLayout from '~/layouts/BaseLayout.astro'

const features = [
    { slug: 'waveform',  label: 'Waveform visualizer',      desc: 'Drag-drop audio → canvas waveform',       ready: true },
    { slug: 'bpm',       label: 'BPM detector',             desc: 'Detect tempo of any audio file',          ready: true },
    { slug: 'tuner',     label: 'Chromatic tuner',          desc: 'Mic input → nearest note + cents',        ready: true },
    { slug: 'metronome', label: 'Metronome',                 desc: 'BPM input → click + visual flash',        ready: true },
    { slug: 'spectrum',  label: 'Frequency spectrum',       desc: 'Real-time FFT visualizer',                ready: true },
    { slug: 'recorder',  label: 'Audio recorder',           desc: 'Mic → record → download WAV/WebM',        ready: true },
    { slug: 'noise',     label: 'Noise generator',          desc: 'White / brown / pink noise via AudioContext', ready: true },
    { slug: 'trimmer',   label: 'Audio trimmer',            desc: 'Set start/end on waveform → download',    ready: true },
]
---
<BaseLayout>
  <article class="home">
    <header class="hero">
      <p class="eyebrow smallcaps">wave · spectrum · level</p>
      <h1 class="h1">Studio-grade audio tools. Pure browser.</h1>
      <p class="lede">Waveform visualizer, BPM detector, tuner, metronome, spectrum analyzer, recorder, noise generator, and trimmer — all powered by the Web Audio API. No uploads, no servers.</p>
      <p class="meta mono">{features.length} tools · 0 bytes uploaded · runs locally</p>
      <div class="cta-row">
        <a href="https://account.oriz.in/sign-in?return=https://audio.oriz.in/" class="btn-primary">Sign in</a>
        <a href="https://oriz.in/pricing?app=echo-audio&return=https://audio.oriz.in/" class="btn-secondary">Upgrade to Pro</a>
      </div>
    </header>

    <section class="grid" aria-label="Tool index">
      {features.map((f, i) => (
        <a href={`/tools/${f.slug}/`} class="card">
          <span class="num mono">{String(i + 1).padStart(2, '0')}</span>
          <div class="card-body">
            <span class="label">{f.label}</span>
            <span class="desc">{f.desc}</span>
          </div>
          <span class={`status mono ${f.ready ? 'ready' : ''}`}>{f.ready ? 'ready' : 'soon'}</span>
        </a>
      ))}
    </section>

    <section class="manifesto">
      <p>
        Oriz Echo runs entirely in your browser using the Web Audio API.
        Files you open are decoded into memory, processed, and saved back —
        nothing is ever sent to a server. No account required for free tools.
      </p>
      <p>
        Source is on <a href="https://github.com/chirag127">GitHub</a>.
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .home { padding-block: 0 2rem; }
  .hero { padding-block: 1rem 2rem; }
  .eyebrow { font-size: 12px; color: var(--muted); margin: 0 0 1rem; }
  .h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 5vw, 3rem);
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin: 0 0 1rem;
  }
  .lede {
    font-size: clamp(1rem, 2.2vw, 1.1875rem);
    color: var(--muted);
    line-height: 1.5;
    margin: 0 0 1rem;
    max-width: 56ch;
  }
  .meta { font-size: 12px; color: var(--muted); letter-spacing: 0.06em; margin: 0 0 1.5rem; }

  .cta-row { display: flex; gap: 0.75rem; flex-wrap: wrap; margin-top: 1.25rem; }
  .btn-primary {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: var(--accent);
    color: var(--paper);
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .btn-primary:hover { opacity: 0.9; }
  .btn-secondary {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background: transparent;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: 4px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .btn-secondary:hover { background: color-mix(in oklab, var(--accent) 10%, transparent); }

  .grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    margin-block: 2rem;
  }
  @media (min-width: 540px) { .grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 860px) { .grid { grid-template-columns: 1fr 1fr 1fr; } }

  .card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 1.125rem;
    background: var(--paper);
    color: var(--ink);
    text-decoration: none;
    transition: background 120ms, color 120ms;
  }
  .card:hover { background: var(--paper-2); color: var(--accent); }
  .card .num { font-size: 11px; color: var(--muted); letter-spacing: 0.08em; min-width: 2ch; }
  .card-body { flex: 1; display: flex; flex-direction: column; gap: 0.2rem; }
  .card .label { font-size: 0.9375rem; }
  .card .desc { font-size: 0.75rem; color: var(--muted); }
  .card:hover .desc { color: color-mix(in oklab, var(--accent) 70%, var(--muted)); }
  .card .status { font-size: 10px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }
  .card .status.ready { color: var(--accent); }

  .manifesto {
    padding-block: 1rem;
    font-size: 0.9375rem;
    line-height: 1.7;
    color: var(--muted);
    max-width: 60ch;
    border-top: 1px solid var(--rule);
    margin-top: 2rem;
    padding-top: 2rem;
  }
  .manifesto p { margin: 0 0 1rem; }
  .manifesto p:last-child { margin-bottom: 0; }
</style>
