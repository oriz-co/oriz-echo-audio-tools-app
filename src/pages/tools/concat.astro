---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Concatenate — Oriz Echo" description="Join multiple audio files end-to-end. Outputs 16-bit PCM WAV.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Concatenate</h1>
    <p class="status mono ready">ready · Web Audio API</p>
    <p class="lede">Pick two or more files; they're decoded and joined in selection order. Sample rate and channel count are normalized to the first file (mismatched files are resampled and channel-converted via the Audio API).</p>

    <div id="drop" class="drop">
      <p>Drop multiple audio files</p>
      <p class="hint mono">or <label class="file-label"><input type="file" id="file" accept="audio/*" multiple /> click to browse</label></p>
    </div>

    <ol id="list" class="list mono"></ol>

    <div class="row">
      <button id="go" class="btn" disabled>Concat &rarr; WAV</button>
      <button id="clear" class="btn-ghost">Clear</button>
      <span id="status" class="status-msg mono"></span>
    </div>
    <p id="err" class="err mono"></p>
  </article>
</BaseLayout>

<script>
  import { decodeFile, encodeWav, downloadBlob, fmtTime } from '~/scripts/audio-utils'
  const drop = document.getElementById('drop')!
  const file = document.getElementById('file') as HTMLInputElement
  const go = document.getElementById('go') as HTMLButtonElement
  const clearBtn = document.getElementById('clear') as HTMLButtonElement
  const list = document.getElementById('list')!
  const status = document.getElementById('status')!
  const err = document.getElementById('err')!
  const files: File[] = []
  function render() {
    list.innerHTML = ''
    files.forEach((x, i) => {
      const li = document.createElement('li')
      li.textContent = `${i + 1}. ${x.name} · ${(x.size / 1024 / 1024).toFixed(2)} MB`
      list.appendChild(li)
    })
    go.disabled = files.length < 2
  }
  function add(fs: FileList | File[]) {
    for (const x of Array.from(fs)) files.push(x)
    render()
  }
  drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('drag-over') })
  drop.addEventListener('dragleave', () => drop.classList.remove('drag-over'))
  drop.addEventListener('drop', (e) => {
    e.preventDefault(); drop.classList.remove('drag-over')
    const fs = (e as DragEvent).dataTransfer?.files; if (fs) add(fs)
  })
  file.addEventListener('change', () => { if (file.files) add(file.files); file.value = '' })
  clearBtn.addEventListener('click', () => { files.length = 0; render(); status.textContent = ''; err.textContent = '' })
  go.addEventListener('click', async () => {
    if (files.length < 2) return
    err.textContent = ''; go.disabled = true
    try {
      status.textContent = 'decoding…'
      const bufs: AudioBuffer[] = []
      for (const x of files) bufs.push(await decodeFile(x))
      const targetSR = bufs[0].sampleRate
      const targetCh = bufs[0].numberOfChannels
      // Render each into a buffer at targetSR/targetCh via OfflineAudioContext, then concat
      const Ctor: any = (window as any).OfflineAudioContext || (window as any).webkitOfflineAudioContext
      const renormed: AudioBuffer[] = []
      let totalLen = 0
      for (const b of bufs) {
        const dur = b.duration
        const len = Math.ceil(dur * targetSR)
        const off = new Ctor(targetCh, Math.max(1, len), targetSR)
        const s = off.createBufferSource(); s.buffer = b; s.connect(off.destination); s.start(0)
        const out: AudioBuffer = await off.startRendering()
        renormed.push(out); totalLen += out.length
      }
      const ctx = new (window.AudioContext || (window as any).webkitAudioContext)()
      const merged = ctx.createBuffer(targetCh, totalLen, targetSR)
      let cursor = 0
      for (const b of renormed) {
        for (let c = 0; c < targetCh; c++) {
          merged.getChannelData(c).set(b.getChannelData(c), cursor)
        }
        cursor += b.length
      }
      status.textContent = 'encoding wav…'
      const blob = encodeWav(merged)
      downloadBlob(blob, `concat.${files.length}files.wav`)
      status.textContent = `done · ${fmtTime(merged.duration)} · ${(blob.size / 1024 / 1024).toFixed(2)} MB`
    } catch (e: any) {
      err.textContent = `failed: ${e?.message || e}`; status.textContent = ''
    } finally { go.disabled = files.length < 2 }
  })
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 1rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 2rem; }
  .drop { width: 100%; min-height: 140px; border: 2px dashed var(--rule); border-radius: 6px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; padding: 2rem; color: var(--muted); text-align: center; }
  .drop.drag-over { border-color: var(--accent); background: color-mix(in oklab, var(--accent) 6%, var(--paper)); }
  .drop p { margin: 0; }
  .hint { font-size: 12px; }
  .file-label { color: var(--accent); cursor: pointer; }
  .file-label input { display: none; }
  .list { margin: 1rem 0 0; padding-left: 1.25rem; font-size: 13px; color: var(--muted); }
  .list li { margin: 0.25rem 0; }
  .row { display: flex; align-items: center; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .btn { background: var(--accent); color: var(--paper); border: none; padding: 0.6rem 1.2rem; font-family: var(--font-mono); font-size: 0.875rem; cursor: pointer; border-radius: 4px; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .btn-ghost { background: transparent; color: var(--muted); border: 1px solid var(--rule); padding: 0.55rem 1rem; font-family: var(--font-mono); font-size: 0.875rem; cursor: pointer; border-radius: 4px; }
  .status-msg { font-size: 12px; color: var(--muted); }
  .err { color: #c1440e; font-size: 12px; margin-top: 0.75rem; min-height: 1.2em; }
</style>
