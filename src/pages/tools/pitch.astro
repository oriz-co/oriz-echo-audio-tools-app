---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Pitch shift — Oriz Echo" description="Shift pitch by semitones using varispeed resampling. Outputs 16-bit PCM WAV.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Pitch shift</h1>
    <p class="status mono ready">ready · Web Audio API</p>
    <p class="lede">Shift by N semitones via varispeed (resampling). Faithful pitch; duration scales inversely — half the semitones up = √2 shorter. Pitch-independent time stretch needs a phase vocoder, not yet shipped.</p>

    <div id="drop" class="drop">
      <p>Drop an audio file</p>
      <p class="hint mono">or <label class="file-label"><input type="file" id="file" accept="audio/*" /> click to browse</label></p>
    </div>

    <div class="grid">
      <label>Semitones (-24 to +24)<input id="semi" type="number" min="-24" max="24" step="1" value="2" /></label>
    </div>

    <div class="row">
      <button id="go" class="btn" disabled>Shift &rarr; WAV</button>
      <span id="status" class="status-msg mono"></span>
    </div>
    <p id="err" class="err mono"></p>
  </article>
</BaseLayout>

<script>
  import { decodeFile, encodeWav, downloadBlob, fmtTime } from '~/scripts/audio-utils'
  const drop = document.getElementById('drop')!
  const file = document.getElementById('file') as HTMLInputElement
  const go = document.getElementById('go') as HTMLButtonElement
  const semi = document.getElementById('semi') as HTMLInputElement
  const status = document.getElementById('status')!
  const err = document.getElementById('err')!
  let f: File | null = null
  let decoded: AudioBuffer | null = null
  async function loadFile(x: File) {
    f = x; err.textContent = ''; status.textContent = `decoding ${x.name}…`
    try {
      decoded = await decodeFile(x); go.disabled = false
      status.textContent = `${x.name} · ${fmtTime(decoded.duration)}`
    } catch (e: any) { err.textContent = `decode failed: ${e?.message || e}` }
  }
  drop.addEventListener('dragover', (e) => { e.preventDefault(); drop.classList.add('drag-over') })
  drop.addEventListener('dragleave', () => drop.classList.remove('drag-over'))
  drop.addEventListener('drop', (e) => {
    e.preventDefault(); drop.classList.remove('drag-over')
    const x = (e as DragEvent).dataTransfer?.files?.[0]; if (x) loadFile(x)
  })
  file.addEventListener('change', () => { if (file.files?.[0]) loadFile(file.files[0]) })
  go.addEventListener('click', async () => {
    if (!decoded || !f) return
    err.textContent = ''
    const n = Math.max(-24, Math.min(24, parseInt(semi.value, 10) || 0))
    const ratio = Math.pow(2, n / 12)
    const sr = decoded.sampleRate
    const outLen = Math.max(1, Math.round(decoded.length / ratio))
    const Ctor: any = (window as any).OfflineAudioContext || (window as any).webkitOfflineAudioContext
    const offline = new Ctor(decoded.numberOfChannels, outLen, sr)
    const src = offline.createBufferSource()
    src.buffer = decoded
    src.playbackRate.value = ratio
    src.connect(offline.destination)
    src.start(0)
    status.textContent = 'rendering…'
    try {
      const out: AudioBuffer = await offline.startRendering()
      const blob = encodeWav(out)
      downloadBlob(blob, f.name.replace(/\.[^.]+$/, '') + `.pitch-${n}st.wav`)
      status.textContent = `done · ${fmtTime(out.duration)} · ${(blob.size / 1024 / 1024).toFixed(2)} MB`
    } catch (e: any) { err.textContent = `render failed: ${e?.message || e}`; status.textContent = '' }
  })
</script>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 1rem; }
  .status.ready { color: var(--accent); }
  .lede { font-size: 1rem; color: var(--muted); line-height: 1.6; max-width: 56ch; margin: 0 0 2rem; }
  .drop { width: 100%; min-height: 140px; border: 2px dashed var(--rule); border-radius: 6px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 0.5rem; padding: 2rem; color: var(--muted); text-align: center; }
  .drop.drag-over { border-color: var(--accent); background: color-mix(in oklab, var(--accent) 6%, var(--paper)); }
  .drop p { margin: 0; }
  .hint { font-size: 12px; }
  .file-label { color: var(--accent); cursor: pointer; }
  .file-label input { display: none; }
  .grid { display: grid; grid-template-columns: 1fr; gap: 1rem; margin-top: 1.25rem; max-width: 280px; }
  .grid label { display: flex; flex-direction: column; gap: 0.35rem; font-size: 12px; color: var(--muted); font-family: var(--font-mono); }
  .grid input { padding: 0.5rem 0.7rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); }
  .row { display: flex; align-items: center; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap; }
  .btn { background: var(--accent); color: var(--paper); border: none; padding: 0.6rem 1.2rem; font-family: var(--font-mono); font-size: 0.875rem; cursor: pointer; border-radius: 4px; }
  .btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .status-msg { font-size: 12px; color: var(--muted); }
  .err { color: #c1440e; font-size: 12px; margin-top: 0.75rem; min-height: 1.2em; }
</style>
